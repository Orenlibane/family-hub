generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ADULT
  KID
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskCategory {
  CHORE
  HOMEWORK
  ERRAND
  HEALTH
  SOCIAL
  OTHER
}

enum Mood {
  GREAT
  GOOD
  OKAY
  SAD
  ANGRY
}

enum RedemptionStatus {
  PENDING
  APPROVED
  REJECTED
  FULFILLED
}

// ==================== HOUSEHOLD ====================
model Household {
  id        String   @id @default(cuid())
  name      String
  inviteCode String  @unique @default(cuid())
  timezone  String   @default("Asia/Jerusalem")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  members     User[]
  tasks       Task[]
  rewards     Reward[]
  events      CalendarEvent[]
  moodLogs    MoodLog[]

  @@index([inviteCode])
}

// ==================== USER ====================
model User {
  id          String   @id @default(cuid())
  email       String   @unique
  googleId    String?  @unique
  name        String
  avatarUrl   String?
  role        Role     @default(KID)
  famCoins    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Household relation
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  // Avatar customization (JSON)
  avatarState Json?

  // Relations
  tasksCreated    Task[]      @relation("TaskCreator")
  tasksAssigned   Task[]      @relation("TaskAssignee")
  tasksCompleted  Task[]      @relation("TaskCompleter")
  rewardsCreated  Reward[]
  redemptions     Redemption[]
  moodLogs        MoodLog[]
  pushSubscriptions PushSubscription[]

  @@index([householdId])
  @@index([email])
  @@index([googleId])
}

// ==================== TASK ====================
model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  category    TaskCategory @default(CHORE)
  status      TaskStatus   @default(PENDING)
  coinReward  Int          @default(10)
  isMustDo    Boolean      @default(false)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  householdId   String
  household     Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  createdById   String
  createdBy     User      @relation("TaskCreator", fields: [createdById], references: [id])

  assignedToId  String?
  assignedTo    User?     @relation("TaskAssignee", fields: [assignedToId], references: [id])

  completedById String?
  completedBy   User?     @relation("TaskCompleter", fields: [completedById], references: [id])

  // Recurrence (JSON)
  recurrence    Json?

  @@index([householdId])
  @@index([status])
  @@index([assignedToId])
  @@index([dueDate])
}

// ==================== REWARD ====================
model Reward {
  id          String   @id @default(cuid())
  name        String
  description String?
  coinCost    Int
  iconUrl     String?
  stock       Int?     // null = unlimited
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  redemptions Redemption[]

  @@index([householdId])
  @@index([isActive])
}

// ==================== REDEMPTION ====================
model Redemption {
  id              String           @id @default(cuid())
  status          RedemptionStatus @default(PENDING)
  coinsSpent      Int
  rejectionReason String?
  fulfilledAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relations
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rewardId String
  reward   Reward @relation(fields: [rewardId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([rewardId])
  @@index([status])
}

// ==================== CALENDAR EVENT ====================
model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String   @default("OTHER")
  startTime   DateTime
  endTime     DateTime?
  isAllDay    Boolean  @default(false)
  location    String?
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  // Participant IDs stored as JSON array
  participantIds Json?

  // Recurrence (JSON)
  recurrence Json?

  @@index([householdId])
  @@index([startTime])
}

// ==================== MOOD LOG ====================
model MoodLog {
  id        String   @id @default(cuid())
  mood      Mood
  note      String?
  createdAt DateTime @default(now())

  // Relations
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([householdId])
  @@index([createdAt])
}

// ==================== PUSH SUBSCRIPTION ====================
model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  keys      Json     // { p256dh, auth }
  createdAt DateTime @default(now())

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([endpoint])
}
