generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ADULT
  KID
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskCategory {
  CHORE
  HOMEWORK
  ERRAND
  HEALTH
  SOCIAL
  OTHER
}

enum Mood {
  GREAT
  GOOD
  OKAY
  SAD
  ANGRY
}

enum RedemptionStatus {
  PENDING
  APPROVED
  REJECTED
  FULFILLED
}

// ==================== POLL ENUMS ====================
enum PollStatus {
  ACTIVE
  CLOSED
}

enum PollCategory {
  MOVIE_NIGHT
  FOOD_CHOICE
  ACTIVITY
  FAMILY_OUTING
  OTHER
}

// ==================== LOGISTICS ENUMS ====================
enum LogisticsCategory {
  PICKUP // איסוף מסגרות
  ACTIVITY // חוגים
  SHOPPING // קניות וסידורים
  CHORE // מטלות
}

// ==================== HOUSEHOLD ====================
model Household {
  id         String   @id @default(cuid())
  name       String
  inviteCode String   @unique @default(cuid())
  timezone   String   @default("Asia/Jerusalem")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  members  User[]
  tasks    Task[]
  rewards  Reward[]
  events   CalendarEvent[]
  moodLogs MoodLog[]

  // New feature relations
  polls          Poll[]
  chatMessages   ChatMessage[]
  logisticsItems LogisticsItem[]

  @@index([inviteCode])
}

// ==================== USER ====================
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  googleId  String?  @unique
  name      String
  avatarUrl String?
  role      Role     @default(KID)
  famCoins  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Household relation
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  // Avatar customization (JSON)
  avatarState Json?

  // Relations
  tasksCreated      Task[]             @relation("TaskCreator")
  tasksAssigned     Task[]             @relation("TaskAssignee")
  tasksCompleted    Task[]             @relation("TaskCompleter")
  rewardsCreated    Reward[]
  redemptions       Redemption[]
  moodLogs          MoodLog[]
  pushSubscriptions PushSubscription[]

  // New feature relations
  childAuth         ChildAuth?
  pollsCreated      Poll[]          @relation("PollCreator")
  votes             Vote[]
  chatMessages      ChatMessage[]
  logisticsAssigned LogisticsItem[] @relation("LogisticsAssignee")
  logisticsCreated  LogisticsItem[] @relation("LogisticsCreator")

  @@index([householdId])
  @@index([email])
  @@index([googleId])
}

// ==================== TASK ====================
model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  category    TaskCategory @default(CHORE)
  status      TaskStatus   @default(PENDING)
  coinReward  Int          @default(10)
  isMustDo    Boolean      @default(false)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("TaskCreator", fields: [createdById], references: [id])

  assignedToId String?
  assignedTo   User?   @relation("TaskAssignee", fields: [assignedToId], references: [id])

  completedById String?
  completedBy   User?   @relation("TaskCompleter", fields: [completedById], references: [id])

  // Recurrence (JSON)
  recurrence Json?

  @@index([householdId])
  @@index([status])
  @@index([assignedToId])
  @@index([dueDate])
}

// ==================== REWARD ====================
model Reward {
  id          String   @id @default(cuid())
  name        String
  description String?
  coinCost    Int
  iconUrl     String?
  stock       Int? // null = unlimited
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  redemptions Redemption[]

  @@index([householdId])
  @@index([isActive])
}

// ==================== REDEMPTION ====================
model Redemption {
  id              String           @id @default(cuid())
  status          RedemptionStatus @default(PENDING)
  coinsSpent      Int
  rejectionReason String?
  fulfilledAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rewardId String
  reward   Reward @relation(fields: [rewardId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([rewardId])
  @@index([status])
}

// ==================== CALENDAR EVENT ====================
model CalendarEvent {
  id          String    @id @default(cuid())
  title       String
  description String?
  category    String    @default("OTHER")
  startTime   DateTime
  endTime     DateTime?
  isAllDay    Boolean   @default(false)
  location    String?
  color       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  // Participant IDs stored as JSON array
  participantIds Json?

  // Recurrence (JSON)
  recurrence Json?

  @@index([householdId])
  @@index([startTime])
}

// ==================== MOOD LOG ====================
model MoodLog {
  id        String   @id @default(cuid())
  mood      Mood
  note      String?
  createdAt DateTime @default(now())

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([householdId])
  @@index([createdAt])
}

// ==================== PUSH SUBSCRIPTION ====================
model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  keys      Json // { p256dh, auth }
  createdAt DateTime @default(now())

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([endpoint])
}

// ==================== CHILD AUTHENTICATION ====================
// For PIN-based child account authentication (no email required)
model ChildAuth {
  id        String   @id @default(cuid())
  username  String
  pinHash   String // Hashed 4-6 digit PIN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([username])
}

// ==================== POLL ====================
model Poll {
  id          String       @id @default(cuid())
  title       String
  description String?
  category    PollCategory @default(OTHER)
  status      PollStatus   @default(ACTIVE)
  closesAt    DateTime? // Optional auto-close time
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("PollCreator", fields: [createdById], references: [id])

  options PollOption[]
  votes   Vote[]

  @@index([householdId])
  @@index([status])
  @@index([createdAt])
}

// ==================== POLL OPTION ====================
model PollOption {
  id        String   @id @default(cuid())
  text      String
  emoji     String? // Optional emoji for visual appeal
  createdAt DateTime @default(now())

  // Relations
  pollId String
  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)

  votes Vote[]

  @@index([pollId])
}

// ==================== VOTE ====================
model Vote {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  pollId String
  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)

  optionId String
  option   PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([userId, pollId]) // One vote per user per poll
  @@index([pollId])
  @@index([userId])
}

// ==================== CHAT MESSAGE ====================
model ChatMessage {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  senderId String
  sender   User   @relation(fields: [senderId], references: [id], onDelete: Cascade)

  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId])
  @@index([createdAt])
}

// ==================== LOGISTICS ITEM ====================
model LogisticsItem {
  id        String            @id @default(cuid())
  title     String
  category  LogisticsCategory
  dayOfWeek Int // 0=Sunday, 6=Saturday
  timeSlot  String? // e.g., "08:00", "15:30"
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  // Relations
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  assignedToId String?
  assignedTo   User?   @relation("LogisticsAssignee", fields: [assignedToId], references: [id])

  createdById String
  createdBy   User   @relation("LogisticsCreator", fields: [createdById], references: [id])

  @@index([householdId])
  @@index([dayOfWeek])
  @@index([assignedToId])
}
