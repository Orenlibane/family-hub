{
  "name": "mishpacha-hub",
  "version": "1.0.0",
  "private": true,
  "description": "MishpachaHub - Family Task Manager",
  "scripts": {
    "install:all": "cd frontend && npm install && cd ../server && npm install",
    "build:frontend": "cd frontend && npm run build",
    "build:server": "cd server && npm run build",
    "build": "npm run build:frontend && npm run copy:frontend && npm run build:server",
    "copy:frontend": "mkdir -p server/public && cp -r frontend/dist/frontend/browser/* server/public/",
    "start": "cd server && npm run start",
    "dev:frontend": "cd frontend && npm start",
    "dev:server": "cd server && npm run dev",
    "db:push": "cd server && npx prisma db push",
    "db:studio": "cd server && npx prisma studio"
  }
}
